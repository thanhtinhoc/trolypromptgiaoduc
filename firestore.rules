rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net default catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable global security helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Helper to validate the structured GameConfig model
    function isValidGameConfig(data, isCreate) {
      return data.userId == request.auth.uid
        && data.gameName is string && data.gameName.size() <= 250
        && data.subject is string && data.subject.size() <= 250
        && data.topic is string && data.topic.size() <= 1000
        && (isCreate ? data.createdAt == request.time : data.createdAt == resource.data.createdAt)
        && data.updatedAt == request.time;
    }

    // Match block for educational game configs collection
    match /game_configs/{configId} {
      allow get: if true; // Allow anyone to read/load a shared educational game config code
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid; // Only list own configs for dashboard security

      allow create: if isSignedIn() 
        && isValidId(configId)
        && isValidGameConfig(incoming(), true);

      allow update: if isSignedIn()
        && isValidId(configId)
        && isValidGameConfig(incoming(), false)
        && existing().userId == request.auth.uid
        // Ensure immutable attributes are untouched during update
        && incoming().userId == existing().userId;

      allow delete: if isSignedIn()
        && isValidId(configId)
        && existing().userId == request.auth.uid;
    }
  }
}
